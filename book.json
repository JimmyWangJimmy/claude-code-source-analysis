{
  "title": "Claude Code 源码深度分析",
  "description": "基于 2026-03-31 npm source map 泄露的 Claude Code TypeScript 源码快照，完整剖析 Anthropic 旗舰 AI 编码 Agent 的架构、安全、多智能体与隐藏功能。",
  "author": "Source Leak Analysis",
  "language": "zh-hans",
  "gitbook": ">=3.2.0",
  "plugins": [
    "theme-default",
    "search",
    "fontsettings",
    "highlight",
    "copy-code-button",
    "-lunr",
    "-sharing",
    "expandable-chapters",
    "code",
    "splitter"
  ],
  "pluginsConfig": {
    "theme-default": {
      "showLevel": true
    },
    "fontsettings": {
      "theme": "white",
      "family": "sans",
      "size": 2
    }
  },
  "structure": {
    "readme": "README.md",
    "summary": "SUMMARY.md"
  }
}
